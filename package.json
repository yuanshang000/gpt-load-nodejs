{
    "name":  "gpt-load-nodejs",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Node.js refactor of gpt-load backend",
    "main":  "dist/index.js",
    "scripts":  {
                    "dev":  "npm run build:web && npm run dev:api",
                    "dev:api":  "tsx watch src/index.ts",
                    "dev:web":  "npm --prefix web run dev",
                    "build":  "tsc -p tsconfig.json",
                    "build:web":  "npm --prefix web run build",
                    "build:all":  "npm run build:web \u0026\u0026 npm run build",
                    "start":  "node dist/index.js",
                    "migrate-keys":  "tsx src/index.ts migrate-keys",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "dev:all":  "concurrently -n api,web -c green,blue \"npm run dev:api\" \"npm run dev:web\""
                },
    "dependencies":  {
                         "@fastify/cors":  "^11.1.0",
                         "@fastify/helmet":  "^13.0.2",
                         "@fastify/multipart":  "^9.2.1",
                         "@fastify/rate-limit":  "^10.3.0",
                         "@fastify/static":  "^8.3.0",
                         "better-sqlite3":  "^12.4.1",
                         "dotenv":  "^17.2.3",
                         "fastify":  "^5.6.1",
                         "nanoid":  "^5.1.6",
                         "redis":  "^5.8.3",
                         "undici":  "^7.16.0"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.13",
                            "@types/node":  "^24.6.0",
                            "concurrently":  "^9.2.1",
                            "tsx":  "^4.20.6",
                            "typescript":  "^5.9.2"
                        }
}
